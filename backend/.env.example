# Development (DEBUG=True) vs Production (DEBUG=False)
DEBUG=False

# Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed domains (add your Render domain here for production)
# Development: localhost,127.0.0.1
# Production: yourdomain.onrender.com,your-custom-domain.com
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.onrender.com

# Database URL (uses dj-database-url)
# Development: sqlite:///db.sqlite3
# Production on Render: PostgreSQL provided by Render (auto-set by Render)
DATABASE_URL=sqlite:///db.sqlite3

# Comma-separated list of frontend URLs that can call the API (CORS)
# Development: http://localhost:5173,http://localhost:3000
# Production: https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT signing key (can be same as SECRET_KEY)
JWT_SECRET_KEY=your-jwt-secret-here

# JWT token lifetimes
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=7
